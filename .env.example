# ==========================================
# Groq API Configuration
# ==========================================
GROQ_API_KEY=your_groq_api_key_here

# ==========================================
# Gemini API Configuration
# (Used for weekly pulse generation if applicable)
# ==========================================
GEMINI_API_KEY=your_gemini_api_key_here

# ==========================================
# Email Configuration
# (Used for sending the weekly pulse in Phase 5)
# ==========================================
# The email address from which the pulse will be sent
SMTP_SENDER_EMAIL=your_sender_email@example.com
# The app password or SMTP password for the sender Email
SMTP_SENDER_PASSWORD=your_app_password_here
# The SMTP server address (e.g., smtp.gmail.com)
SMTP_SERVER=smtp.gmail.com
# The SMTP server port (usually 587 for TLS or 465 for SSL)
SMTP_PORT=587
# The recipient email address
SMTP_RECIPIENT_EMAIL=your_recipient_email@example.com

# ==========================================
# Review Scraper Configuration
# ==========================================
# The Google Play Store app ID (e.g., com.nextbillion.groww)
APP_ID=com.nextbillion.groww
# Language for reviews
APP_LANGUAGE=en
# Country code for reviews
APP_COUNTRY=in
# Total number of reviews to fetch per batch
MAX_REVIEWS_TO_FETCH=1000
# Target timeframe (e.g., fetch last 4 weeks of reviews)
WEEKS_TO_FETCH=4

# ==========================================
# Model Configuration
# ==========================================
# Default model name for Groq inference
GROQ_MODEL_NAME=llama-3.3-70b-versatile

# ==========================================
# Scheduler Configuration
# ==========================================
SCHEDULER_INTERVAL_MINUTES=5
SCHEDULER_RECIPIENT_EMAIL=your_recipient_email_here
SCHEDULER_RECIPIENT_NAME=Atharv
SCHEDULER_WEEKS=8
SCHEDULER_MAX_REVIEWS=1000
